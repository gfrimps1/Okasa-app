# Server port (Railway sets this automatically)
PORT=3001

# JWT secret — use a strong random string in production!
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-random-secret

# SQLite database path
DB_PATH=./okasa.db

# Upload directory
UPLOAD_DIR=./uploads

# Node environment
NODE_ENV=production

# ── AI Avatar Generation ──

# Kling AI API credentials (https://app.klingai.com/global/dev)
# Sign up and get API key + secret from the developer portal
KLING_API_KEY=
KLING_API_SECRET=
KLING_API_BASE_URL=https://api.klingai.com

# Abena AI TTS API key (coming soon — https://abena.mobobi.com)
# Currently uses Google Translate TTS as free fallback
ABENA_API_KEY=

# TTS provider: google (default/free) | abena (when available)
TTS_PROVIDER=google

# Max video upload size in MB
MAX_VIDEO_UPLOAD_MB=50

# Number of parallel Kling API calls (use 1 on Railway free tier)
AVATAR_GENERATION_CONCURRENCY=2
